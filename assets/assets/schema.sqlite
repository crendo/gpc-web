  `totaliva` REAL DEFAULT 0.0,
  `totalislr` REAL DEFAULT 0.0,
  `totalgarlab` REAL DEFAULT 0.0,
  `totalfielcump` REAL DEFAULT 0.0,
  `desde` TEXT DEFAULT NULL,
  `hasta` TEXT DEFAULT NULL
);

-- Table: receipts
DROP TABLE IF EXISTS `receipts`;
CREATE TABLE `receipts` (
