  `porcentajeutilidad` REAL NOT NULL DEFAULT 0.0,
  `bonoalimento` REAL NOT NULL DEFAULT 0.0,
  `piva` REAL NOT NULL DEFAULT 0.0,
  `ivaenapu` INTEGER NOT NULL DEFAULT 0,
  `p_imprevistos` REAL NOT NULL DEFAULT 0.0,
  `horaextradiurna` REAL DEFAULT 0.0,
  `horaextranocturna` REAL DEFAULT 0.0,
  `horanocturna` REAL DEFAULT 0.0,
  `horanocturnaextra` REAL DEFAULT 0.0,
  `horadominical` REAL DEFAULT 0.0,
  `horadominicalextra` REAL DEFAULT 0.0,
  `horafestiva` REAL DEFAULT 0.0,
  `horafestivaextra` REAL DEFAULT 0.0,
  `horaextradiurnafestiva` REAL DEFAULT 0.0,
  `horaextranocturnafestiva` REAL DEFAULT 0.0,
  `horaextradiurnadominical` REAL DEFAULT 0.0,
  `horaextranocturnadominical` REAL DEFAULT 0.0,
  `horas_semanales` REAL DEFAULT 40.0
);

