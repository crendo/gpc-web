  `receipt_id` INTEGER NOT NULL,
  `item_no` TEXT,
  `description` TEXT,
  `unit` TEXT,
  `quantity` REAL DEFAULT 0.0,
  `price` REAL DEFAULT 0.0,
  `total` REAL DEFAULT 0.0,
  FOREIGN KEY (`receipt_id`) REFERENCES `receipts` (`id`) ON DELETE CASCADE
);

