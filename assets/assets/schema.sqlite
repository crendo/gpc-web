-- Table: maestro
DROP TABLE IF EXISTS `maestro`;
CREATE TABLE `maestro` (
  `idmaestro` INTEGER PRIMARY KEY AUTOINCREMENT,
  `codigo` TEXT NOT NULL DEFAULT '',
  `costo` REAL NOT NULL DEFAULT 0.0,
  `fecha` TEXT NOT NULL,
  `codprov` TEXT NOT NULL DEFAULT ''
);

-- Table: materiales
DROP TABLE IF EXISTS `materiales`;
CREATE TABLE `materiales` (
  `codigo` TEXT PRIMARY KEY, 
  `codfam` TEXT, 
  `descripcion` TEXT, 
  `unidad` TEXT, 
  `factor` REAL, 
  `dp` REAL DEFAULT 0, 
  `flag` TEXT DEFAULT 'M'
);

-- Table: equipos
DROP TABLE IF EXISTS `equipos`;
CREATE TABLE `equipos` (
  `codigo` TEXT PRIMARY KEY, 
  `codfam` TEXT, 
  `descripcion` TEXT, 
  `unidad` TEXT, 
  `factor` REAL, 
  `dp` REAL DEFAULT 0, 
  `flag` TEXT DEFAULT 'E'
);

-- Table: manodeobra
DROP TABLE IF EXISTS `manodeobra`;
CREATE TABLE `manodeobra` (
  `codigo` TEXT PRIMARY KEY, 
  `codfam` TEXT, 
  `descripcion` TEXT, 
  `unidad` TEXT, 
