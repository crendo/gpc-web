);

-- Table: familia
DROP TABLE IF EXISTS `familia`;
CREATE TABLE `familia` (
  `codfam` TEXT PRIMARY KEY, 
  `meo` TEXT, 
  `descripcion` TEXT
);

-- View: insumos
DROP TABLE IF EXISTS `insumos`;
DROP VIEW IF EXISTS `insumos`;
CREATE VIEW insumos AS 
SELECT * FROM materiales 
UNION ALL 
SELECT * FROM equipos 
UNION ALL 
SELECT * FROM manodeobra;

-- View: insumos_con_costo
DROP TABLE IF EXISTS `insumos_con_costo`;
DROP VIEW IF EXISTS `insumos_con_costo`;
CREATE VIEW insumos_con_costo AS
SELECT i.*, m.costo as punit, m.fecha as fecha_precio, m.idmaestro as idmaestro
FROM insumos i
LEFT JOIN maestro m ON m.idmaestro = (
  SELECT m2.idmaestro FROM maestro m2 
  WHERE m2.codigo = i.codigo 
  ORDER BY m2.fecha DESC, m2.idmaestro DESC 
  LIMIT 1
);

-- Table: valores_por_defecto
DROP TABLE IF EXISTS `valores_por_defecto`;
CREATE TABLE `valores_por_defecto` (
