  `updated_at` TEXT DEFAULT (datetime('now'))
);

-- APU Indexes
CREATE INDEX IF NOT EXISTS idx_apu_master_codpart ON apu_master(codpart);
CREATE INDEX IF NOT EXISTS idx_apu_master_detalles_parent ON apu_master_detalles(idapumaster);
CREATE UNIQUE INDEX IF NOT EXISTS idx_maestro_codigo_fecha_prov ON maestro(codigo, fecha, codprov);
CREATE INDEX IF NOT EXISTS idx_materiales_codfam ON materiales(codfam);
CREATE INDEX IF NOT EXISTS idx_equipos_codfam ON equipos(codfam);
CREATE INDEX IF NOT EXISTS idx_manodeobra_codfam ON manodeobra(codfam);
CREATE INDEX IF NOT EXISTS idx_familia_lookup ON familia(codfam, meo);

PRAGMA foreign_keys = ON;
